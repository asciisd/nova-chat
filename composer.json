{
    "name": "asciisd/nova-chat",
    "description": "A reusable, contract-driven WhatsApp-style chat tool for Laravel Nova.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/nova": "^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "Asciisd\\NovaChat\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Asciisd\\NovaChat\\NovaChatServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}